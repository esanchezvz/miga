{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env", ".env.development"],
  "globalEnv": ["*"],
  "tasks": {
    "build": {
      "outputs": ["dist/**"]
    },
    "clean": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "cache": true,
      "dependsOn": ["^typecheck"]
    }
  }
}
